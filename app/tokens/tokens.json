{
  "$metadata": {
    "tokenSetOrder": ["color", "radius", "spacing", "elevation", "font"]
  },

  "color": {

    "background":  { "$type": "color", "$value": "#111420", "$description": "App background / page chrome" },
    "surface-dim": { "$type": "color", "$value": "#171B29", "$description": "Nav, persistent UI" },

    "surface": {
      "white": { "$type": "color", "$value": "#FFFFFF" },
      "light": { "$type": "color", "$value": "#F8FAFC" },
      "gray":  { "$type": "color", "$value": "#F1F5F9" }
    },

    "dark": {
      "base":      { "$type": "color", "$value": "#0D0F1A", "$description": "Off-black — deepest dark" },
      "primary":   { "$type": "color", "$value": "#1A1D29", "$description": "Primary dark background" },
      "secondary": { "$type": "color", "$value": "#252A36", "$description": "Secondary dark background" },
      "tertiary":  { "$type": "color", "$value": "#3D4451", "$description": "Tertiary dark elements" }
    },

    "text": {
      "primary":   { "$type": "color", "$value": "#F7F8FF", "$description": "Primary text" },
      "secondary": { "$type": "color", "$value": "#C3CAD8", "$description": "Supporting text" },
      "muted":     { "$type": "color", "$value": "#8B94A8", "$description": "Muted text, metadata" },
      "disabled":  { "$type": "color", "$value": "#5D667A", "$description": "Placeholders, inactive" },
      "inverse":   { "$type": "color", "$value": "#111420", "$description": "Text on light surfaces" }
    },

    "brand": {
      "purple-light": { "$type": "color", "$value": "#B3B8FF" },
      "purple":       { "$type": "color", "$value": "#8B92FF", "$description": "Brand primary — Neon Indigo" },
      "purple-dark":  { "$type": "color", "$value": "#6B72E8" },

      "coral-light": { "$type": "color", "$value": "#FF8F82" },
      "coral":       { "$type": "color", "$value": "#FF6B5A", "$description": "Brand accent — Coral Ember" },
      "coral-dark":  { "$type": "color", "$value": "#E64A37" },

      "blue-light": { "$type": "color", "$value": "#7E85E6" },
      "blue":       { "$type": "color", "$value": "#5B63D6", "$description": "Brand secondary — Indigo" },
      "blue-dark":  { "$type": "color", "$value": "#4850B8" },

      "teal":       { "$type": "color", "$value": "#6B9DB0" },
      "teal-hover": { "$type": "color", "$value": "#8CB5C5" },
      "pink":       { "$type": "color", "$value": "#E85D9C" },
      "recording":  { "$type": "color", "$value": "#FF5A4F", "$description": "Live recording indicator" }
    },

    "semantic": {
      "success-light": { "$type": "color", "$value": "#86EFAC" },
      "success":       { "$type": "color", "$value": "#2ECC71" },
      "success-dark":  { "$type": "color", "$value": "#16A34A" },

      "warning-light": { "$type": "color", "$value": "#FCD384" },
      "warning":       { "$type": "color", "$value": "#F5A623" },
      "warning-dark":  { "$type": "color", "$value": "#C47D10" },

      "error-light": { "$type": "color", "$value": "#FF8586" },
      "error":       { "$type": "color", "$value": "#FF4D4F" },
      "error-dark":  { "$type": "color", "$value": "#CC1F21" },

      "info-light": { "$type": "color", "$value": "#93C5FD" },
      "info":       { "$type": "color", "$value": "#4DA3FF" },
      "info-dark":  { "$type": "color", "$value": "#1D6FBF" }
    },

    "data": {
      "account":  { "$type": "color", "$value": "#6B9DB0" },
      "recency":  { "$type": "color", "$value": "#8B92FF" },
      "crm-sync": { "$type": "color", "$value": "#2ECC71" },
      "review":   { "$type": "color", "$value": "#F5A623" }
    },

    "alpha": {
      "white-10":    { "$type": "color", "$value": "rgba(255, 255, 255, 0.10)" },
      "white-18":    { "$type": "color", "$value": "rgba(255, 255, 255, 0.18)" },
      "purple-10":   { "$type": "color", "$value": "rgba(179, 184, 255, 0.10)" },
      "purple-glass":{ "$type": "color", "$value": "rgba(179, 184, 255, 0.10)" },
      "dark-glass":  { "$type": "color", "$value": "rgba(255, 255, 255, 0.18)" }
    },

    "ext": {
      "cyan":   { "$type": "color", "$value": "#5BBFCC" },
      "lime":   { "$type": "color", "$value": "#89B347" },
      "orange": { "$type": "color", "$value": "#C97A42" },
      "gold":   { "$type": "color", "$value": "#C4962B" },
      "violet": { "$type": "color", "$value": "#8875C4" },
      "rose":   { "$type": "color", "$value": "#C97888" }
    },

    "neutral": {
      "950": { "$type": "color", "$value": "#0A0A0A" },
      "800": { "$type": "color", "$value": "#262626" },
      "600": { "$type": "color", "$value": "#525252" },
      "400": { "$type": "color", "$value": "#A3A3A3" },
      "200": { "$type": "color", "$value": "#E5E5E5" },
      "50":  { "$type": "color", "$value": "#FAFAFA" }
    }
  },

  "radius": {
    "none": { "$type": "dimension", "$value": "0px",   "$description": "M3: No radius" },
    "xs":   { "$type": "dimension", "$value": "4px",   "$description": "M3: Extra Small" },
    "sm":   { "$type": "dimension", "$value": "8px",   "$description": "M3: Small" },
    "md":   { "$type": "dimension", "$value": "12px",  "$description": "M3: Medium" },
    "lg":   { "$type": "dimension", "$value": "16px",  "$description": "M3: Large" },
    "xl":   { "$type": "dimension", "$value": "28px",  "$description": "M3: Extra Large" },
    "full": { "$type": "dimension", "$value": "100px", "$description": "M3: Full / pill" }
  },

  "spacing": {
    "1":  { "$type": "dimension", "$value": "4px" },
    "2":  { "$type": "dimension", "$value": "8px" },
    "3":  { "$type": "dimension", "$value": "12px" },
    "4":  { "$type": "dimension", "$value": "16px" },
    "5":  { "$type": "dimension", "$value": "20px" },
    "6":  { "$type": "dimension", "$value": "24px" },
    "8":  { "$type": "dimension", "$value": "32px" },
    "10": { "$type": "dimension", "$value": "40px" },
    "12": { "$type": "dimension", "$value": "48px" },
    "16": { "$type": "dimension", "$value": "64px" }
  },

  "elevation": {
    "0": { "$type": "shadow", "$value": "none" },
    "1": { "$type": "shadow", "$value": { "offsetX": "0", "offsetY": "1px", "blur": "2px",  "spread": "0",   "color": "rgba(0,0,0,0.35)" } },
    "2": { "$type": "shadow", "$value": { "offsetX": "0", "offsetY": "1px", "blur": "2px",  "spread": "0",   "color": "rgba(0,0,0,0.35)" } },
    "3": { "$type": "shadow", "$value": { "offsetX": "0", "offsetY": "4px", "blur": "8px",  "spread": "3px", "color": "rgba(0,0,0,0.20)" } },
    "4": { "$type": "shadow", "$value": { "offsetX": "0", "offsetY": "6px", "blur": "10px", "spread": "4px", "color": "rgba(0,0,0,0.20)" } }
  },

  "font": {
    "family": {
      "sans":  { "$type": "fontFamily", "$value": ["Barlow", "system-ui", "sans-serif"],             "$description": "UI body text" },
      "serif": { "$type": "fontFamily", "$value": ["Roboto Slab", "Georgia", "serif"],               "$description": "Display headings" },
      "icon":  { "$type": "fontFamily", "$value": ["Material Symbols Rounded"],                      "$description": "Icon font" }
    },
    "weight": {
      "regular":   { "$type": "fontWeight", "$value": 400 },
      "medium":    { "$type": "fontWeight", "$value": 500 },
      "semibold":  { "$type": "fontWeight", "$value": 600 },
      "bold":      { "$type": "fontWeight", "$value": 700 },
      "extrabold": { "$type": "fontWeight", "$value": 800 }
    }
  },

  "typography": {
    "heading-1": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.serif}", "fontWeight": "{font.weight.bold}", "fontSize": "60px", "lineHeight": "66px" }
    },
    "heading-2": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.serif}", "fontWeight": "{font.weight.bold}", "fontSize": "48px", "lineHeight": "58px" }
    },
    "heading-3": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.serif}", "fontWeight": "{font.weight.bold}", "fontSize": "36px", "lineHeight": "43px" }
    },
    "heading-4": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.serif}", "fontWeight": "{font.weight.bold}", "fontSize": "24px", "lineHeight": "31px" }
    },
    "heading-5": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.serif}", "fontWeight": "{font.weight.bold}", "fontSize": "20px", "lineHeight": "26px" }
    },
    "heading-6": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.serif}", "fontWeight": "{font.weight.bold}", "fontSize": "18px", "lineHeight": "24px" }
    },
    "text-xl-bold": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.sans}", "fontWeight": "{font.weight.semibold}", "fontSize": "20px", "lineHeight": "30px" }
    },
    "text-lg-bold": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.sans}", "fontWeight": "{font.weight.semibold}", "fontSize": "18px", "lineHeight": "27px" }
    },
    "text-base-bold": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.sans}", "fontWeight": "{font.weight.semibold}", "fontSize": "16px", "lineHeight": "24px" }
    },
    "text-sm-bold": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.sans}", "fontWeight": "{font.weight.semibold}", "fontSize": "14px", "lineHeight": "21px" }
    },
    "text-xs-bold": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.sans}", "fontWeight": "{font.weight.semibold}", "fontSize": "12px", "lineHeight": "18px" }
    },
    "eyebrow": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.sans}", "fontWeight": "{font.weight.semibold}", "fontSize": "14px", "lineHeight": "20px", "letterSpacing": "1px", "textTransform": "uppercase" }
    },
    "subheadline-lg": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.sans}", "fontWeight": "{font.weight.regular}", "fontSize": "24px", "lineHeight": "36px" }
    },
    "subheadline-md": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.sans}", "fontWeight": "{font.weight.regular}", "fontSize": "20px", "lineHeight": "30px" }
    },
    "label-serif": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.serif}", "fontWeight": "{font.weight.regular}", "fontSize": "10px", "lineHeight": "14px" }
    },
    "text-2xs": {
      "$type": "typography",
      "$value": { "fontFamily": "{font.family.sans}", "fontWeight": "{font.weight.regular}", "fontSize": "10px", "lineHeight": "14px" }
    }
  }
}
